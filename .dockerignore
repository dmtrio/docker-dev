# Plugin host-side launchers (run on the Mac via ./service.sh <name>) and plugin
# docs never belong inside a container. Keep them out of the build context so
# `COPY plugins /opt/plugins` carries only each plugin's plugin.yml (+ any baked
# assets). The Dockerfile bake loop globs plugins/*/plugin.yml, so this is a
# cleanliness guarantee, not a functional dependency.
plugins/*/run.sh
plugins/README.md
plugins/*/README.md
