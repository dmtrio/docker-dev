.DS_Store
# repo-local config + runtime home (secrets, keys, artifacts) — never commit
.env
.dev-agent/
secrets.env
# personal container manifests carry semi-private data (private repo URLs, LAN
# subnets, identity-ref naming) — keep only the generic TEMPLATE.yml
containers/*.yml
!containers/TEMPLATE.yml
# generated into each container's workspace at up time (and symlinked into
# worktrees) — only visible to git when the workspace repo is this one
.mcp.json
# serena plugin's per-project state (LSP cache + agent-written memories)
.serena/
