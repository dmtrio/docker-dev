# Container capability profile: coding
# Grants: MCP gateway 'coding' profile (Playwright, port 8811),
# Proxyman bridge (port 8813), Obsidian Annotated egress + per-agent keys.
# Selected with: ./new-local-container.sh coding

HOST_MCP_PORTS="8811,8813"
EXTRA_ALLOWED_DOMAINS="mcp-obsidian.dmetr.io"

# Prompt for a per-agent Obsidian Annotated scoped key at launch?
PROMPT_OBSIDIAN_KEY=true

# AI tools baked into the image build
INSTALL_CLAUDE=true
INSTALL_PI=true
INSTALL_GEMINI=true
INSTALL_CURSOR=true
INSTALL_AIDER=true

# Container memory cap
MEM_LIMIT=10g
INSTALL_CODEX=true
