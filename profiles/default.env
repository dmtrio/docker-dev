# Container capability profile: default
# Fully sandboxed — no host MCP access, no extra egress domains.
# Selected with: ./new-local-container.sh default   (or just press enter)

HOST_MCP_PORTS=""
EXTRA_ALLOWED_DOMAINS=""

# Prompt for a per-agent Obsidian Annotated scoped key at launch?
PROMPT_OBSIDIAN_KEY=false

# AI tools baked into the image build
INSTALL_CLAUDE=true
INSTALL_PI=true
INSTALL_GEMINI=true
INSTALL_CURSOR=true
INSTALL_AIDER=true

# Container memory cap
MEM_LIMIT=2g
