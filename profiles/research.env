# Container capability profile: research
# Grants: watchable browser on YOUR desktop (Brave/Chrome, isolated profile,
# port 8814 — start run-research-browser.sh first) + Obsidian Annotated
# egress with per-agent keys. No headless browsing: everything is visible.
# Selected with: ./new-local-container.sh research

HOST_MCP_PORTS="8814"
EXTRA_ALLOWED_DOMAINS="mcp-obsidian.dmetr.io"

# Prompt for a per-agent Obsidian Annotated scoped key at launch?
PROMPT_OBSIDIAN_KEY=true

# AI tools baked into the image build
INSTALL_CLAUDE=true
INSTALL_PI=true
INSTALL_GEMINI=true
INSTALL_CURSOR=true
INSTALL_AIDER=true

# Container memory cap
MEM_LIMIT=4g
